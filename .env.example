# Golden Hill Boxing Club — environment variables
# Copy to .env for local dev. Every var here must also be set in Vercel
# (Project → Settings → Environment Variables) for preview/production.

# ---- Database (Neon Postgres) ----
# Pooled connection string (PgBouncer) — used at runtime.
DATABASE_URL=""
# Direct (unpooled) connection — used for migrations / prisma db push.
DATABASE_URL_UNPOOLED=""

# ---- Auth (NextAuth) ----
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# ---- Cloudflare Turnstile (bot protection on login/signup) ----
# Create a widget at https://dash.cloudflare.com → Turnstile.
# Both keys REQUIRED in production — without them the check is skipped.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ---- Square payments ----
# Sandbox credentials from https://developer.squareup.com/apps → your app.
# Build + test against sandbox first; swap to production keys at launch.
PAYMENTS_ENABLED="false"
SQUARE_ENVIRONMENT="sandbox"            # sandbox | production
SQUARE_ACCESS_TOKEN=""
NEXT_PUBLIC_SQUARE_APP_ID=""            # a.k.a. SQUARE_APPLICATION_ID
NEXT_PUBLIC_SQUARE_LOCATION_ID=""       # a.k.a. SQUARE_LOCATION_ID
# Webhook signature key (Developer dashboard → Webhooks → your subscription).
SQUARE_WEBHOOK_SIGNATURE_KEY=""

# ---- Email (Resend) ----
# Free tier at https://resend.com — used for password resets, booking
# confirmations, claim-account links, and waitlist promotions.
RESEND_API_KEY=""
EMAIL_FROM="Golden Hill Boxing Club <noreply@goldenhillboxingclub.com>"

# ---- Misc ----
# Public site URL (used in emailed links).
NEXT_PUBLIC_SITE_URL="https://ghbc-redesign.vercel.app"
# Vercel Blob (avatar uploads) — auto-set when the Blob store is connected.
BLOB_READ_WRITE_TOKEN=""
