// Golden Hill Boxing Club — data model
// Postgres (Neon) in all environments. String fields stand in for enums;
// allowed values are centralised in lib/constants.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (PgBouncer) — used at runtime
  directUrl = env("DATABASE_URL_UNPOOLED") // direct — used for migrations/db push
}

model User {
  id                 String    @id @default(cuid())
  firstName          String
  lastName           String
  email              String    @unique
  phone              String?
  image              String?   // avatar URL (Vercel Blob)
  passwordHash       String
  role               String    @default("MEMBER") // MEMBER | COACH | OWNER
  membershipType     String    @default("FULL")   // FULL | YOGA | TRIAL | NONE
  squareCustomerId   String?
  subscriptionStatus String    @default("active")  // active | past_due | paused | cancelled | pending_claim
  classesGoal        Int       @default(100)
  // Liability waiver acceptance (required at signup — both membership & trial).
  waiverAcceptedAt   DateTime?
  // Owner's manual rewards adjustment (+/-) added to the attended-class count —
  // corrections and grandfathered members' historical classes.
  classCountAdjust   Int       @default(0)
  // Trial buyers get exactly ONE class credit; consumed on booking.
  trialClassCredits  Int       @default(0)
  // When the post-trial "$99 first month" follow-up email went out (cron).
  trialFollowUpAt    DateTime?
  createdAt          DateTime  @default(now())
  bookings           Booking[]
  coach              Coach?    // set when this account is a coach's login
  resetTokens        PasswordResetToken[]
  announcementReads  AnnouncementRead[]
  membership         Membership?
  notifications      Notification[]
  claimTokens        ClaimToken[]
  rewardMilestones   RewardMilestone[]
}

// The money-side record for a member. Square is the source of truth for what
// gets charged; this row links the member to their Square customer +
// subscription and mirrors the billing status (kept in sync by webhooks).
model Membership {
  id                   String     @id @default(cuid())
  user                 User       @relation(fields: [userId], references: [id])
  userId               String     @unique
  plan                 String // TRIAL | FULL | SIX_MONTH | TWELVE_MONTH | GRANDFATHERED | PROMO
  status               String     @default("active") // active | past_due | paused | cancelled | pending_claim | expired
  squareCustomerId     String?
  squareSubscriptionId String?
  // For prepaid blocks (6/12-month) — membership runs until this date.
  prepaidUntil         DateTime?
  promoCode            PromoCode? @relation(fields: [promoCodeId], references: [id])
  promoCodeId          String?
  startedAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

// Owner-managed promo codes. percentOff 100 + payment skip = free membership.
model PromoCode {
  id          String       @id @default(cuid())
  code        String       @unique
  percentOff  Int          @default(100)
  // FOREVER = ongoing free membership (owner revokes by cancelling);
  // FIRST_MONTH = discount applies to the first month only.
  duration    String       @default("FOREVER") // FOREVER | FIRST_MONTH
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  memberships Membership[]
}

// In-dashboard notifications (waitlist promotions, payment issues, …).
// Drives the banner/badge in the member dashboard; readAt set on view.
model Notification {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  title     String
  body      String
  createdAt DateTime  @default(now())
  readAt    DateTime?
}

// Single-use "claim your account" / coach-invite magic-link tokens (hash
// stored, raw token emailed) — same pattern as PasswordResetToken.
model ClaimToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  tokenHash String   @unique
  purpose   String   @default("CLAIM") // CLAIM (member migration) | COACH_INVITE
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// Rewards milestones a member has hit (100 / 250 / 500 classes). The gold glow
// persists while redeemedAt is null; celebratedAt records that the confetti
// popup was shown & acknowledged so it doesn't re-fire every visit.
model RewardMilestone {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id])
  userId       String
  milestone    Int // 100 | 250 | 500
  reachedAt    DateTime  @default(now())
  celebratedAt DateTime?
  redeemedAt   DateTime?

  @@unique([userId, milestone])
}

// Single-use password-reset tokens (the raw token is emailed; only its hash is
// stored). Expired/used rows are deleted on use.
model PasswordResetToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Coach {
  id          String          @id @default(cuid())
  name        String
  bio         String?
  specialty   String? // e.g. "Boxing · Muay Thai"
  // Deactivated coaches keep their history but can't sign in / take classes.
  active      Boolean         @default(true)
  // Optional login account (role COACH). Coaches without a login are display-only.
  user        User?           @relation(fields: [userId], references: [id])
  userId      String?         @unique
  templates     ClassTemplate[]
  sessions      ClassSession[]  @relation("SessionCoach")
  subSessions   ClassSession[]  @relation("SubCoach")
  announcements Announcement[]
}

// Recurring weekly slot — the source the visible week is generated from.
model ClassTemplate {
  id        String         @id @default(cuid())
  classType String // Boxing | Muay Thai | Yoga | Open Gym
  coach     Coach?         @relation(fields: [coachId], references: [id])
  coachId   String?
  dayOfWeek Int // 0=Sun .. 6=Sat
  startMin  Int // minutes from midnight
  endMin    Int
  capacity  Int            @default(10)
  active    Boolean        @default(true)
  sessions  ClassSession[]
}

// Concrete dated instance bookings attach to. Generated on demand from a
// template for a given date (upsert keyed on templateId + startAt).
model ClassSession {
  id         String         @id @default(cuid())
  template   ClassTemplate? @relation(fields: [templateId], references: [id])
  templateId String?
  classType  String
  coach      Coach?         @relation("SessionCoach", fields: [coachId], references: [id])
  coachId    String?
  // Substitute coach covering this one session. Set by a coach from their
  // dashboard; overlays the scheduled coach and is NEVER touched by session
  // regeneration (ensureSessionsForWeek's update path leaves it alone), so a
  // cover survives re-viewing the week.
  subCoach   Coach?         @relation("SubCoach", fields: [subCoachId], references: [id])
  subCoachId String?
  startAt    DateTime
  endAt      DateTime
  capacity   Int            @default(10)
  // Owner can cancel a single dated class (one-off) or a whole day (holiday /
  // closure). Cancelled sessions are hidden from the public schedule and are
  // preserved across regeneration. One-off classes added by the owner have
  // templateId = null.
  cancelled  Boolean        @default(false)
  // Set when the owner edits THIS occurrence only ("this class only") — session
  // regeneration then never overwrites its time/coach/capacity from the template.
  edited     Boolean        @default(false)
  bookings   Booking[]

  @@unique([templateId, startAt])
}

// A gym-wide day off (holiday, maintenance, etc.). When a date is closed,
// ensureSessionsForWeek skips generating classes on it and cancels any that
// already exist, so the schedule shows the day closed.
model Closure {
  id        String   @id @default(cuid())
  date      DateTime @unique // local midnight of the closed day
  reason    String?
  createdAt DateTime @default(now())
}

// A message a coach broadcasts to every member. It pops up once in each
// member's dashboard; dismissing records an AnnouncementRead.
model Announcement {
  id         String             @id @default(cuid())
  coach      Coach?             @relation(fields: [coachId], references: [id])
  coachId    String?
  authorName String // snapshot of the coach's name at send time
  message    String
  createdAt  DateTime           @default(now())
  reads      AnnouncementRead[]
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  announcementId String
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  createdAt      DateTime     @default(now())

  @@unique([announcementId, userId])
}

model Booking {
  id        String       @id @default(cuid())
  user      User         @relation(fields: [userId], references: [id])
  userId    String
  session   ClassSession @relation(fields: [sessionId], references: [id])
  sessionId String
  status    String       @default("BOOKED") // BOOKED | CANCELLED | ATTENDED
  createdAt DateTime     @default(now())

  @@unique([userId, sessionId])
}
