// Golden Hill Boxing Club — data model
// Postgres (Neon) in all environments. String fields stand in for enums;
// allowed values are centralised in lib/constants.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (PgBouncer) — used at runtime
  directUrl = env("DATABASE_URL_UNPOOLED") // direct — used for migrations/db push
}

model User {
  id                 String    @id @default(cuid())
  firstName          String
  lastName           String
  email              String    @unique
  phone              String?
  image              String?   // avatar URL (Vercel Blob)
  passwordHash       String
  role               String    @default("MEMBER") // MEMBER | COACH | OWNER
  membershipType     String    @default("FULL")   // FULL | YOGA | TRIAL | NONE
  squareCustomerId   String?
  subscriptionStatus String    @default("active")  // active | past_due | cancelled
  classesGoal        Int       @default(100)
  createdAt          DateTime  @default(now())
  bookings           Booking[]
  coach              Coach?    // set when this account is a coach's login
  resetTokens        PasswordResetToken[]
  announcementReads  AnnouncementRead[]
}

// Single-use password-reset tokens (the raw token is emailed; only its hash is
// stored). Expired/used rows are deleted on use.
model PasswordResetToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Coach {
  id          String          @id @default(cuid())
  name        String
  bio         String?
  // Optional login account (role COACH). Coaches without a login are display-only.
  user        User?           @relation(fields: [userId], references: [id])
  userId      String?         @unique
  templates     ClassTemplate[]
  sessions      ClassSession[]  @relation("SessionCoach")
  subSessions   ClassSession[]  @relation("SubCoach")
  announcements Announcement[]
}

// Recurring weekly slot — the source the visible week is generated from.
model ClassTemplate {
  id        String         @id @default(cuid())
  classType String // Boxing | Muay Thai | Yoga | Open Gym
  coach     Coach?         @relation(fields: [coachId], references: [id])
  coachId   String?
  dayOfWeek Int // 0=Sun .. 6=Sat
  startMin  Int // minutes from midnight
  endMin    Int
  capacity  Int            @default(10)
  active    Boolean        @default(true)
  sessions  ClassSession[]
}

// Concrete dated instance bookings attach to. Generated on demand from a
// template for a given date (upsert keyed on templateId + startAt).
model ClassSession {
  id         String         @id @default(cuid())
  template   ClassTemplate? @relation(fields: [templateId], references: [id])
  templateId String?
  classType  String
  coach      Coach?         @relation("SessionCoach", fields: [coachId], references: [id])
  coachId    String?
  // Substitute coach covering this one session. Set by a coach from their
  // dashboard; overlays the scheduled coach and is NEVER touched by session
  // regeneration (ensureSessionsForWeek's update path leaves it alone), so a
  // cover survives re-viewing the week.
  subCoach   Coach?         @relation("SubCoach", fields: [subCoachId], references: [id])
  subCoachId String?
  startAt    DateTime
  endAt      DateTime
  capacity   Int            @default(10)
  // Owner can cancel a single dated class (one-off) or a whole day (holiday /
  // closure). Cancelled sessions are hidden from the public schedule and are
  // preserved across regeneration. One-off classes added by the owner have
  // templateId = null.
  cancelled  Boolean        @default(false)
  bookings   Booking[]

  @@unique([templateId, startAt])
}

// A gym-wide day off (holiday, maintenance, etc.). When a date is closed,
// ensureSessionsForWeek skips generating classes on it and cancels any that
// already exist, so the schedule shows the day closed.
model Closure {
  id        String   @id @default(cuid())
  date      DateTime @unique // local midnight of the closed day
  reason    String?
  createdAt DateTime @default(now())
}

// A message a coach broadcasts to every member. It pops up once in each
// member's dashboard; dismissing records an AnnouncementRead.
model Announcement {
  id         String             @id @default(cuid())
  coach      Coach?             @relation(fields: [coachId], references: [id])
  coachId    String?
  authorName String // snapshot of the coach's name at send time
  message    String
  createdAt  DateTime           @default(now())
  reads      AnnouncementRead[]
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  announcementId String
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  createdAt      DateTime     @default(now())

  @@unique([announcementId, userId])
}

model Booking {
  id        String       @id @default(cuid())
  user      User         @relation(fields: [userId], references: [id])
  userId    String
  session   ClassSession @relation(fields: [sessionId], references: [id])
  sessionId String
  status    String       @default("BOOKED") // BOOKED | CANCELLED | ATTENDED
  createdAt DateTime     @default(now())

  @@unique([userId, sessionId])
}
